tion-300\"><div hidden=\"\"><!--$--><!--/$--></div><script>((a,b,c,d,e,f,g,h)=>{let i=document.documentElement,j=[\"light\",\"dark\"];function k(b){var c;(Array.isArray(a)?a:[a]).forEach(a=>{let c=\"class\"===a,d=c&&f?e.map(a=>f[a]||a):e;c?(i.classList.remove(...d),i.classList.add(f&&f[b]?f[b]:b)):i.setAttribute(a,b)}),c=b,h&&j.includes(c)&&(i.style.colorScheme=c)}if(d)k(d);else try{let a=localStorage.getItem(b)||c,d=g&&\"system\"===a?window.matchMedia(\"(prefers-color-scheme: dark)\").matches?\"dark\":\"light\":a;k(d)}catch(a){}})(\"class\",\"theme\",\"system\",null,[\"light\",\"dark\"],null,true,true)</script><main class=\"min-h-screen bg-background text-foreground flex flex-col justify-between\"><div class=\"relative overflow-hidden animate-silk py-6 border-b border-border/40\"><div aria-hidden=\"true\" class=\"pointer-events-none absolute inset-0 bg-white/10 backdrop-blur-[1px]\"></div><div class=\"relative mx-auto w-full max-w-6xl px-6 lg:px-8\"><header class=\"w-full relative z-50\"><div class=\"flex items-center justify-between py-4\"><a class=\"flex items-center gap-3 relative z-[60]\" href=\"/\"><div class=\"relative h-8 w-8 shrink-0\"><img alt=\"The Startup Desk Logo\" decoding=\"async\" data-nimg=\"fill\" class=\"object-contain dark:brightness-0 dark:invert\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=%2FLogo.png&amp;w=640&amp;q=75 640w, /_next/image?url=%2FLogo.png&amp;w=750&amp;q=75 750w, /_next/image?url=%2FLogo.png&amp;w=828&amp;q=75 828w, /_next/image?url=%2FLogo.png&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2FLogo.png&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2FLogo.png&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2FLogo.png&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2FLogo.png&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2FLogo.png&amp;w=3840&amp;q=75\"/></div><span class=\"font-display text-lg font-extrabold tracking-tight text-foreground whitespace-nowrap\">The Startup Desk</span></a><nav class=\"hidden items-center gap-6 md:flex\"><a class=\"text-sm font-medium text-muted-foreground transition-colors hover:text-foreground\" href=\"/services\">Services</a><a class=\"text-sm font-medium text-muted-foreground transition-colors hover:text-foreground\" href=\"/resources\">Resources</a><a class=\"text-sm font-medium text-muted-foreground transition-colors hover:text-foreground\" href=\"/faq\">FAQ</a><a class=\"text-sm font-medium text-muted-foreground transition-colors hover:text-foreground\" href=\"/about\">About</a><a class=\"text-sm font-medium text-muted-foreground transition-colors hover:text-foreground\" href=\"/contact\">Contact</a><button class=\"relative inline-flex h-9 w-9 items-center justify-center rounded-lg border border-primary/10 bg-white/80 dark:bg-black/40 backdrop-blur-sm text-primary transition-all duration-300 hover:scale-105\" aria-label=\"Toggle visual theme mode\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-sun h-[1.2rem] w-[1.2rem] rotate-0 scale-100 transition-all dark:-rotate-90 dark:scale-0 text-accent\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"4\"></circle><path d=\"M12 2v2\"></path><path d=\"M12 20v2\"></path><path d=\"m4.93 4.93 1.41 1.41\"></path><path d=\"m17.66 17.66 1.41 1.41\"></path><path d=\"M2 12h2\"></path><path d=\"M20 12h2\"></path><path d=\"m6.34 17.66-1.41 1.41\"></path><path d=\"m19.07 4.93-1.41 1.41\"></path></svg><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-moon absolute h-[1.2rem] w-[1.2rem] rotate-90 scale-0 transition-all dark:rotate-0 dark:scale-100 text-blue-400\" aria-hidden=\"true\"><path d=\"M20.985 12.486a9 9 0 1 1-9.473-9.472c.405-.022.617.46.402.803a6 6 0 0 0 8.268 8.268c.344-.215.825-.004.803.401\"></path></svg></button><a href=\"https://wa.me/2348137941914?text=Hi%20The%20Startup%20Desk%2C%20I&#x27;d%20like%20to%20talk%20about%20compliance%20for%20my%20startup.\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"inline-flex items-center gap-1.5 rounded-lg border border-whatsapp bg-whatsapp px-3.5 py-2 text-sm font-medium text-whatsapp-foreground transition-colors hover:bg-whatsapp/90\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-message-circle h-4 w-4\" aria-hidden=\"true\"><path d=\"M2.992 16.342a2 2 0 0 1 .094 1.167l-1.065 3.29a1 1 0 0 0 1.236 1.168l3.413-.998a2 2 0 0 1 1.099.092 10 10 0 1 0-4.777-4.719\"></path></svg>Talk to us</a></nav><div class=\"flex items-center gap-2 md:hidden relative z-[60]\"><button class=\"relative inline-flex h-9 w-9 items-center justify-center rounded-lg border border-primary/10 bg-white/80 dark:bg-black/40 backdrop-blur-sm text-primary transition-all duration-300 hover:scale-105\" aria-label=\"Toggle visual theme mode\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-sun h-[1.2rem] w-[1.2rem] rotate-0 scale-100 transition-all dark:-rotate-90 dark:scale-0 text-accent\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"4\"></circle><path d=\"M12 2v2\"></path><path d=\"M12 20v2\"></path><path d=\"m4.93 4.93 1.41 1.41\"></path><path d=\"m17.66 17.66 1.41 1.41\"></path><path d=\"M2 12h2\"></path><path d=\"M20 12h2\"></path><path d=\"m6.34 17.66-1.41 1.41\"></path><path d=\"m19.07 4.93-1.41 1.41\"></path></svg><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-moon absolute h-[1.2rem] w-[1.2rem] rotate-90 scale-0 transition-all dark:rotate-0 dark:scale-100 text-blue-400\" aria-hidden=\"true\"><path d=\"M20.985 12.486a9 9 0 1 1-9.473-9.472c.405-.022.617.46.402.803a6 6 0 0 0 8.268 8.268c.344-.215.825-.004.803.401\"></path></svg></button><button class=\"inline-flex h-9 w-9 items-center justify-center rounded-lg border border-border bg-white dark:bg-black text-foreground transition-all focus:outline-none\" aria-label=\"Toggle Navigation Menu\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu h-5 w-5\" aria-hidden=\"true\"><path d=\"M4 5h16\"></path><path d=\"M4 12h16\"></path><path d=\"M4 19h16\"></path></svg></button></div></div></header><div class=\"mx-auto max-w-3xl py-16 text-center md:py-24\"><span class=\"animate-fade-in-up inline-flex items-center gap-2 rounded-full border border-accent/20 bg-white/90 backdrop-blur-md px-4 py-2 text-xs font-bold tracking-wider text-accent\">Our Mission</span><h1 class=\"animate-fade-in-up mt-6 font-display text-4xl font-extrabold leading-[1.1] tracking-tight text-primary sm:text-5xl lg:text-6xl\" style=\"animation-delay:100ms\">We started The Startup Desk because compliance shouldn&#x27;t be the reason a good business fails.</h1><p class=\"animate-fade-in-up mx-auto mt-6 max-w-2xl text-lg md:text-xl font-medium leading-relaxed text-muted-foreground\" style=\"animation-delay:200ms\">Not because founders don&#x27;t care, because nobody hands you the manual.</p></div></div></div><section class=\"mx-auto w-full max-w-6xl px-6 py-16 lg:px-8 lg:py-24\"><div class=\"grid gap-16 lg:grid-cols-2 lg:items-start\"><div class=\"space-y-6\"><div class=\"inline-flex h-10 w-10 items-center justify-center rounded-xl bg-accent/10 text-accent\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-compass h-5 w-5\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m16.24 7.76-1.804 5.411a2 2 0 0 1-1.265 1.265L7.76 16.24l1.804-5.411a2 2 0 0 1 1.265-1.265z\"></path></svg></div><h2 class=\"font-display text-3xl font-extrabold tracking-tight text-primary sm:text-4xl\">The gap nobody warns you about</h2><div class=\"text-base md:text-lg leading-relaxed text-muted-foreground space-y-4\"><p>Getting your CAC certificate feels like the finish line. It&#x27;s actually the starting line. What comes after, annual returns, tax registration, statutory registers, data protection rules, rarely gets explained clearly and even more rarely gets explained in time.</p><p class=\"border-l-4 border-accent pl-4 font-medium text-primary italic bg-muted/40 py-2 rounded-r-xl\">We&#x27;ve sat across from founders who did everything right at incorporation and still got caught out eighteen months later by a filing they didn&#x27;t know existed. Not because they were careless. Because nobody told them, and Google gives you ten different half-answers.</p><p>The Startup Desk exists to close that gap, plainly, consistently, and before it becomes a problem instead of after.</p></div></div><div class=\"space-y-6 lg:p-8 lg:bg-muted/30 lg:rounded-3xl lg:border lg:border-border/60\"><div class=\"inline-flex h-10 w-10 items-center justify-center rounded-xl bg-accent/10 text-accent\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-scale h-5 w-5\" aria-hidden=\"true\"><path d=\"M12 3v18\"></path><path d=\"m19 8 3 8a5 5 0 0 1-6 0zV7\"></path><path d=\"M3 7h1a17 17 0 0 0 8-2 17 17 0 0 0 8 2h1\"></path><path d=\"m5 8 3 8a5 5 0 0 1-6 0zV7\"></path><path d=\"M7 21h10\"></path></svg></div><h2 class=\"font-display text-3xl font-extrabold tracking-tight text-primary sm:text-4xl\">Built on a compliance background, built for founders</h2><div class=\"text-base leading-relaxed text-muted-foreground space-y-4\"><p>The Startup Desk was founded on a legal compliance background, not to give you legal advice, but to translate regulation into steps you can actually act on. <span class=\"font-bold text-primary\">We&#x27;re a compliance consultancy, not a law firm.</span> That distinction matters: we&#x27;re not here to represent you in a dispute. We&#x27;re here to make sure you never end up in one over something preventable.</p><p>Where something genuinely requires legal representation, we&#x27;ll tell you plainly and point you to a licensed lawyer we trust. Most of what threatens early-stage companies isn&#x27;t a legal battle, it&#x27;s a missed deadline or a document filed wrong. That&#x27;s our lane, and we know it well.</p></div></div></div></section><section class=\"bg-primary text-primary-foreground py-16 lg:py-20 relative overflow-hidden\"><div aria-hidden=\"true\" class=\"absolute -right-24 -bottom-24 h-64 w-64 rounded-full bg-accent/10 blur-2xl\"></div><div class=\"mx-auto max-w-4xl px-6 text-center relative\"><h2 class=\"font-display text-3xl font-extrabold tracking-tight sm:text-4xl text-white\">No jargon. No scare tactics. Just what&#x27;s actually required.</h2><p class=\"mt-6 text-lg md:text-xl leading-relaxed text-white/80 max-w-3xl mx-auto\">We explain the <span class=\"text-accent font-bold\">why</span> behind every requirement, not just the what, because founders who understand the stakes make better decisions than founders who are just following a checklist blindly. We keep things in plain English, we tell you what happens if something&#x27;s missed, and we handle the parts you&#x27;d rather not learn how to do yourself.</p></div></section><section class=\"mx-auto w-full max-w-6xl px-6 py-16 lg:py-24\"><div class=\"text-center max-w-2xl mx-auto mb-12\"><h2 class=\"font-display text-3xl font-extrabold tracking-tight text-primary sm:text-4xl\">What we stand for</h2></div><div class=\"grid gap-6 sm:grid-cols-2 lg:grid-cols-4\"><div class=\"bg-card border border-border p-6 rounded-2xl shadow-sm hover:shadow-md transition-all\"><span class=\"text-xl font-bold text-accent mb-2 block\">01</span><h3 class=\"font-display font-bold text-lg text-primary\">Plain English, always.</h3><p class=\"mt-2 text-sm leading-relaxed text-muted-foreground\">If we can&#x27;t explain it simply, we haven&#x27;t understood it well enough ourselves.</p></div><div class=\"bg-card border border-border p-6 rounded-2xl shadow-sm hover:shadow-md transition-all\"><span class=\"text-xl font-bold text-accent mb-2 block\">02</span><h3 class=\"font-display font-bold text-lg text-primary\">Prevention over rescue.</h3><p class=\"mt-2 text-sm leading-relaxed text-muted-foreground\">We&#x27;d rather get you ahead of a deadline than help you recover from missing one.</p></div><div class=\"bg-card border border-border p-6 rounded-2xl shadow-sm hover:shadow-md transition-all\"><span class=\"text-xl font-bold text-accent mb-2 block\">03</span><h3 class=\"font-display font-bold text-lg text-primary\">Honest about our lane.</h3><p class=\"mt-2 text-sm leading-relaxed text-muted-foreground\">Compliance consulting, not legal representation, and we&#x27;ll tell you when you need the latter.</p></div><div class=\"bg-card border border-border p-6 rounded-2xl shadow-sm hover:shadow-md transition-all\"><span class=\"text-xl font-bold text-accent mb-2 block\">04</span><h3 class=\"font-display font-bold text-lg text-primary\">Built for where you are.</h3><p class=\"mt-2 text-sm leading-relaxed text-muted-foreground\">Whether you&#x27;re three weeks or three years post-incorporation, the advice should fit your stage, not a generic template.</p></div></div></section><section class=\"mx-auto w-full max-w-6xl px-6 pb-24 lg:px-8\"><div class=\"relative overflow-hidden rounded-3xl bg-gradient-to-br from-primary to-primary/95 px-6 py-14 text-center text-primary-foreground shadow-2xl md:px-12\"><div aria-hidden=\"true\" class=\"pointer-events-none absolute inset-0\"><div class=\"absolute -right-16 -top-16 h-64 w-64 rounded-full bg-accent/10 blur-xl\"></div><div class=\"absolute -bottom-20 -left-10 h-56 w-56 rounded-full bg-white/5 blur-lg\"></div></div><div class=\"relative max-w-2xl mx-auto space-y-6\"><h2 class=\"font-display text-3xl font-extrabold tracking-tight text-white sm:text-5xl\">Ready to stop guessing what&#x27;s required?</h2><div class=\"inline-flex items-center gap-2 bg-white/10 backdrop-blur-md px-4 py-1.5 rounded-full text-xs font-semibold tracking-wide text-accent border border-white/10\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check-big h-3.5 w-3.5\" aria-hidden=\"true\"><path d=\"M21.801 10A10 10 0 1 1 17 3.335\"></path><path d=\"m9 11 3 3L22 4\"></path></svg>Registered with CAC Nigeria • RC: <!-- -->9668977</div><div class=\"mt-8 flex flex-col sm:flex-row justify-center items-center gap-4 pt-4\"><a class=\"group relative inline-flex w-full sm:w-auto items-center justify-center gap-2 overflow-hidden rounded-xl bg-accent px-8 py-4 text-base font-bold text-accent-foreground transition-all hover:bg-accent/90 shadow-sm\" href=\"/register\">Get Started<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-right h-5 w-5 transition-transform group-hover:translate-x-1\" aria-hidden=\"true\"><path d=\"M5 12h14\"></path><path d=\"m12 5 7 7-7 7\"></path></svg></a><a href=\"https://wa.me/2348137941914?text=Hi%20The%20Startup%20Desk%2C%20I%20want%20to%20review%20my%20company&#x27;s%20post-incorporation%20status.\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"group inline-flex w-full sm:w-auto items-center justify-center gap-2 rounded-xl border-2 border-white/20 bg-white/10 backdrop-blur-sm px-8 py-4 text-base font-bold text-white transition-all hover:bg-white/20\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-message-circle h-5 w-5 text-white transition-transform group-hover:rotate-12\" aria-hidden=\"true\"><path d=\"M2.992 16.342a2 2 0 0 1 .094 1.167l-1.065 3.29a1 1 0 0 0 1.236 1.168l3.413-.998a2 2 0 0 1 1.099.092 10 10 0 1 0-4.777-4.719\"></path></svg>Chat on WhatsApp</a></div></div></div></section><footer class=\"border-t border-border bg-muted/40 mt-auto\"><div class=\"mx-auto max-w-6xl px-6 py-14 lg:px-8\"><div class=\"grid gap-10 md:grid-cols-[1.4fr_1fr_1fr_1fr]\"><div class=\"max-w-sm space-y-4\"><a class=\"flex items-center gap-2.5\" href=\"/\"><span class=\"flex h-9 w-9 items-center justify-center rounded-lg bg-primary text-primary-foreground\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-shield-check h-5 w-5\" aria-hidden=\"true\"><path d=\"M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z\"></path><path d=\"m9 12 2 2 4-4\"></path></svg></span><span class=\"font-display text-lg font-semibold tracking-tight text-primary\">The Startup Desk</span></a><p class=\"text-xs leading-relaxed text-muted-foreground\">Compliance handled from your first CAC filing to your first funding round. A compliance consultancy for early-stage Nigerian startups, not a law firm.</p></div><div><p class=\"text-xs font-bold uppercase tracking-wider text-primary\">Explore</p><ul class=\"mt-4 flex flex-col gap-3 text-xs font-semibold\"><li><a class=\"text-muted-foreground transition-colors hover:text-primary\" href=\"/services\">Services</a></li><li><a class=\"text-muted-foreground transition-colors hover:text-primary\" href=\"/about\">About</a></li><li><a class=\"text-muted-foreground transition-colors hover:text-primary\" href=\"/resources\">Resources Hub</a></li><li><a class=\"text-muted-foreground transition-colors hover:text-primary\" href=\"/faq\">FAQ</a></li></ul></div><div><p class=\"text-xs font-bold uppercase tracking-wider text-primary\">Legal &amp; Compliance</p><ul class=\"mt-4 flex flex-col gap-3 text-xs font-semibold\"><li><a class=\"text-muted-foreground transition-colors hover:text-primary\" href=\"/privacy\">Privacy Policy</a></li><li><a class=\"text-muted-foreground transition-colors hover:text-primary\" href=\"/terms\">Terms of Service</a></li><li><a class=\"text-muted-foreground transition-colors hover:text-primary\" href=\"/disclosures\">Regulatory Disclosures</a></li></ul></div><div><p class=\"text-xs font-bold uppercase tracking-wider text-primary\">Get in touch</p><ul class=\"mt-4 flex flex-col gap-3 text-xs font-semibold\"><li><a href=\"mailto:the.start.up.desk1@gmail.com\" class=\"flex items-center gap-2 text-muted-foreground transition-colors hover:text-primary\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-mail h-4 w-4 text-accent\" aria-hidden=\"true\"><path d=\"m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7\"></path><rect x=\"2\" y=\"4\" width=\"20\" height=\"16\" rx=\"2\"></rec