l,\"$L10\"]}],{},null,false]},null,false]},null,false],\"$L11\",false]],\"m\":\"$undefined\",\"G\":[\"$12\",[]],\"s\":false,\"S\":true}\n13:I[2619,[\"296\",\"static/chunks/296-8f2e822e76f9f738.js\",\"220\",\"static/chunks/app/about/page-8acf75d4755a5525.js\"],\"\"]\n16:I[4431,[],\"OutletBoundary\"]\n18:I[5278,[],\"AsyncMetadataOutlet\"]\n1a:I[4431,[],\"ViewportBoundary\"]\n1c:I[4431,[],\"MetadataBoundary\"]\n1d:\"$Sreact.suspense\"\n9:[\"$\",\"h2\",null,{\"className\":\"font-display text-3xl font-extrabold tracking-tight text-primary sm:text-4xl\",\"children\":\"The gap nobody warns you about\"}]\na:[\"$\",\"div\",null,{\"className\":\"text-base md:text-lg leading-relaxed text-muted-foreground space-y-4\",\"children\":[[\"$\",\"p\",null,{\"children\":\"Getting your CAC certificate feels like the finish line. It's actually the starting line. What comes after, annual returns, tax registration, statutory registers, data protection rules, rarely gets explained clearly and even more rarely gets explained in time.\"}],[\"$\",\"p\",null,{\"className\":\"border-l-4 border-accent pl-4 font-medium text-primary italic bg-muted/40 py-2 rounded-r-xl\",\"children\":\"We've sat across from founders who did everything right at incorporation and still got caught out eighteen months later by a filing they didn't know existed. Not because they were careless. Because nobody told them, and Google gives you ten different half-answers.\"}],[\"$\",\"p\",null,{\"children\":\"The Startup Desk exists to close that gap, plainly, consistently, and before it becomes a problem instead of after.\"}]]}]\nb:[\"$\",\"div\",null,{\"className\":\"space-y-6 lg:p-8 lg:bg-muted/30 lg:rounded-3xl lg:border lg:border-border/60\",\"children\":[[\"$\",\"div\",null,{\"className\":\"inline-flex h-10 w-10 items-center justify-center rounded-xl bg-accent/10 text-accent\",\"children\":[\"$\",\"$L8\",null,{\"ref\":\"$undefined\",\"iconNode\":[[\"path\",{\"d\":\"M12 3v18\",\"key\":\"108xh3\"}],[\"path\",{\"d\":\"m19 8 3 8a5 5 0 0 1-6 0zV7\",\"key\":\"zcdpyk\"}],[\"path\",{\"d\":\"M3 7h1a17 17 0 0 0 8-2 17 17 0 0 0 8 2h1\",\"key\":\"1yorad\"}],[\"path\",{\"d\":\"m5 8 3 8a5 5 0 0 1-6 0zV7\",\"key\":\"eua70x\"}],[\"path\",{\"d\":\"M7 21h10\",\"key\":\"1b0cd5\"}]],\"className\":\"lucide-scale h-5 w-5\"}]}],[\"$\",\"h2\",null,{\"className\":\"font-display text-3xl font-extrabold tracking-tight text-primary sm:text-4xl\",\"children\":\"Built on a compliance background, built for founders\"}],[\"$\",\"div\",null,{\"className\":\"text-base leading-relaxed text-muted-foreground space-y-4\",\"children\":[[\"$\",\"p\",null,{\"children\":[\"The Startup Desk was founded on a legal compliance background, not to give you legal advice, but to translate regulation into steps you can actually act on. \",[\"$\",\"span\",null,{\"className\":\"font-bold text-primary\",\"children\":\"We're a compliance consultancy, not a law firm.\"}],\" That distinction matters: we're not here to represent you in a dispute. We're here to make sure you never end up in one over something preventable.\"]}],[\"$\",\"p\",null,{\"children\":\"Where something genuinely requires legal representation, we'll tell you plainly and point you to a licensed lawyer we trust. Most of what threatens early-stage companies isn't a legal battle, it's a missed deadline or a document filed wrong. That's our lane, and we know it well.\"}]]}]]}]\nc:[\"$\",\"section\",null,{\"className\":\"bg-primary text-primary-foreground py-16 lg:py-20 relative overflow-hidden\",\"children\":[[\"$\",\"div\",null,{\"aria-hidden\":\"true\",\"className\":\"absolute -right-24 -bottom-24 h-64 w-64 rounded-full bg-accent/10 blur-2xl\"}],[\"$\",\"div\",null,{\"className\":\"mx-auto max-w-4xl px-6 text-center relative\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-display text-3xl font-extrabold tracking-tight sm:text-4xl text-white\",\"children\":\"No jargon. No scare tactics. Just what's actually required.\"}],[\"$\",\"p\",null,{\"className\":\"mt-6 text-lg md:text-xl leading-relaxed text-white/80 max-w-3xl mx-auto\",\"children\":[\"We explain the \",[\"$\",\"span\",null,{\"className\":\"text-accent font-bold\",\"children\":\"why\"}],\" behind every requirement, not just the what, because founders who understand the stakes make better decisions than founders who are just following a checklist blindly. We keep things in plain English, we tell you what happens if something's missed, and we handle the parts you'd rather not learn how to do yourself.\"]}]]}]]}]\nd:[\"$\",\"section\",null,{\"className\":\"mx-auto w-full max-w-6xl px-6 py-16 lg:py-24\",\"children\":[[\"$\",\"div\",null,{\"className\":\"text-center max-w-2xl mx-auto mb-12\",\"children\":[\"$\",\"h2\",null,{\"className\":\"font-display text-3xl font-extrabold tracking-tight text-primary sm:text-4xl\",\"children\":\"What we stand for\"}]}],[\"$\",\"div\",null,{\"className\":\"grid gap-6 sm:grid-cols-2 lg:grid-cols-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"bg-card border border-border p-6 rounded-2xl shadow-sm hover:shadow-md transition-all\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-xl font-bold text-accent mb-2 block\",\"children\":\"01\"}],[\"$\",\"h3\",null,{\"className\":\"font-display font-bold text-lg text-primary\",\"children\":\"Plain English, always.\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm leading-relaxed text-muted-foreground\",\"children\":\"If we can't explain it simply, we haven't understood it well enough ourselves.\"}]]}],[\"$\",\"div\",null,{\"className\":\"bg-card border border-border p-6 rounded-2xl shadow-sm hover:shadow-md transition-all\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-xl font-bold text-accent mb-2 block\",\"children\":\"02\"}],[\"$\",\"h3\",null,{\"className\":\"font-display font-bold text-lg text-primary\",\"children\":\"Prevention over rescue.\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm leading-relaxed text-muted-foreground\",\"children\":\"We'd rather get you ahead of a deadline than help you recover from missing one.\"}]]}],[\"$\",\"div\",null,{\"className\":\"bg-card border border-border p-6 rounded-2xl shadow-sm hover:shadow-md transition-all\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-xl font-bold text-accent mb-2 block\",\"children\":\"03\"}],[\"$\",\"h3\",null,{\"className\":\"font-display font-bold text-lg text-primary\",\"children\":\"Honest about our lane.\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm leading-relaxed text-muted-foreground\",\"children\":\"Compliance consulting, not legal representation, and we'll tell you when you need the latter.\"}]]}],[\"$\",\"div\",null,{\"className\":\"bg-card border border-border p-6 rounded-2xl shadow-sm hover:shadow-md transition-all\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-xl font-bold text-accent mb-2 block\",\"children\":\"04\"}],[\"$\",\"h3\",null,{\"className\":\"font-display font-bold text-lg text-primary\",\"children\":\"Built for where you are.\"}],[\"$\",\"p\",null,{\"className\":\"mt-2 text-sm leading-relaxed text-muted-foreground\",\"children\":\"Whether you're three weeks or three years post-incorporation, the advice should fit your stage, not a generic template.\"}]]}]]}]]}]\ne:[\"$\",\"section\",null,{\"className\":\"mx-auto w-full max-w-6xl px-6 pb-24 lg:px-8\",\"children\":[\"$\",\"div\",null,{\"className\":\"relative overflow-hidden rounded-3xl bg-gradient-to-br from-primary to-primary/95 px-6 py-14 text-center text-primary-foreground shadow-2xl md:px-12\",\"children\":[[\"$\",\"div\",null,{\"aria-hidden\":\"true\",\"className\":\"pointer-events-none absolute inset-0\",\"children\":[[\"$\",\"div\",null,{\"className\":\"absolute -right-16 -top-16 h-64 w-64 rounded-full bg-accent/10 blur-xl\"}],[\"$\",\"div\",null,{\"className\":\"absolute -bottom-20 -left-10 h-56 w-56 rounded-full bg-white/5 blur-lg\"}]]}],[\"$\",\"div\",null,{\"className\":\"relative max-w-2xl mx-auto space-y-6\",\"children\":[[\"$\",\"h2\",nul